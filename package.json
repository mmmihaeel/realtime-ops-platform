{
  "name": "realtime-ops-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Operational workflow platform built with NestJS microservices, PostgreSQL, RabbitMQ, Redis, and WebSockets.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start:api": "node dist/apps/api-gateway/src/main.js",
    "start:processing": "node dist/apps/processing-service/src/main.js",
    "start:realtime": "node dist/apps/realtime-gateway/src/main.js",
    "start:dev:api": "ts-node -r tsconfig-paths/register --project tsconfig.json apps/api-gateway/src/main.ts",
    "start:dev:processing": "ts-node -r tsconfig-paths/register --project tsconfig.json apps/processing-service/src/main.ts",
    "start:dev:realtime": "ts-node -r tsconfig-paths/register --project tsconfig.json apps/realtime-gateway/src/main.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "db:migrate": "ts-node -r tsconfig-paths/register --project tsconfig.json scripts/migrate.ts",
    "db:seed": "ts-node -r tsconfig-paths/register --project tsconfig.json scripts/seed.ts",
    "db:setup": "ts-node -r tsconfig-paths/register --project tsconfig.json scripts/db-setup.ts",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down --remove-orphans",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.6",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/amqplib": "^0.10.7",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}

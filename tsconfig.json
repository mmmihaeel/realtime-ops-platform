{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@app/common": ["libs/common/src/index.ts"],
      "@app/common/*": ["libs/common/src/*"],
      "@app/core": ["libs/core/src/index.ts"],
      "@app/core/*": ["libs/core/src/*"],
      "@app/database": ["libs/database/src/index.ts"],
      "@app/database/*": ["libs/database/src/*"],
      "@app/messaging": ["libs/messaging/src/index.ts"],
      "@app/messaging/*": ["libs/messaging/src/*"],
      "@app/redis": ["libs/redis/src/index.ts"],
      "@app/redis/*": ["libs/redis/src/*"],
      "@app/application": ["libs/application/src/index.ts"],
      "@app/application/*": ["libs/application/src/*"],
      "@app/auth": ["libs/auth/src/index.ts"],
      "@app/auth/*": ["libs/auth/src/*"]
    },
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "incremental": true,
    "types": ["node", "jest"]
  },
  "include": ["apps/**/*.ts", "libs/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}

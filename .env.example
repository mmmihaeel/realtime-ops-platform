NODE_ENV=development
API_PORT=3001
REALTIME_PORT=3002

DATABASE_URL=postgres://app:app@postgres:5432/realtime_ops
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379

OPERATOR_API_TOKEN=ops-local-token
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
REALTIME_EVENTS_QUEUE=realtime.gateway.events
